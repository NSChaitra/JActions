name: deploy-solution-to-prod

on:
  workflow_dispatch:
  release:
    types: [created]

jobs:
  deploy-solution:
    runs-on: windows-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          lfs: true

      # Ensure output folder exists
      - name: Create output folders
        shell: pwsh
        run: |
          New-Item -ItemType Directory -Force -Path "out\solutions\Managed" | Out-Null
          New-Item -ItemType Directory -Force -Path "out\release\Managed" | Out-Null

      - name: Pack solution (Managed)
        uses: microsoft/powerplatform-actions/pack-solution@v0
        with:
          solution-folder: "src/solutions/Unmanaged/GitHubActionsDevOpsDemo"
          solution-file: "out/solutions/Managed/GitHubActionsDevOpsDemo.zip"
          solution-type: "Managed"

      - name: Verify packed zip exists
        shell: pwsh
        run: |
          if (!(Test-Path "out\solutions\Managed\GitHubActionsDevOpsDemo.zip")) {
            throw "Packed solution zip not found at out\\solutions\\Managed\\GitHubActionsDevOpsDemo.zip"
          }
          Get-Item "out\solutions\Managed\GitHubActionsDevOpsDemo.zip" | Format-List

      - name: Upload artifact (Managed solution)
        uses: actions/upload-artifact@v4
        with:
          name: managedSolutions
          path: "out/solutions/Managed/GitHubActionsDevOpsDemo.zip"

      - name: Download artifact (into expected import folder)
        uses: actions/download-artifact@v4
        with:
          name: managedSolutions
          path: "out/release/Managed"

      - name: List downloaded files
        shell: pwsh
        run: |
          Get-ChildItem -Path ".\out\release\Managed" -Recurse | Format-Table -AutoSize

      - name: Import solution to production
        uses: microsoft/powerplatform-actions/import-solution@v0
        with:
          environment-url: "https://powerplatcoe-old.crm.dynamics.com/"
          app-id: "4fec5240-fd45-408b-8276-d60c97798c49"
          client-secret: ${{ secrets.PASSWORD }}
          tenant-id: "db05faca-c82a-4b9d-b9c5-0f64b6755421"
          solution-file: "out/release/Managed/GitHubActionsDevOpsDemo.zip"
          force-overwrite: true
          publish-changes: true
``
